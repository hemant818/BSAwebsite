generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model Appointment {
  id               String      @id @default(cuid())
  bookingId        String      @unique
  patientName      String
  age              Int
  gender           Gender
  phone            String
  email            String
  complaint        String      @db.Text
  preferredDate    DateTime
  timeSlot         String
  consultationType ConsultType
  status           Status      @default(PENDING)
  doctorNotes      String?     @db.Text
  source           String?
  whatsappSent     Boolean     @default(false)
  emailSent        Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  phone        String
  loginAttempts Int      @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime  @default(now())
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ConsultType {
  IN_CLINIC
  ONLINE
}

enum Status {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
